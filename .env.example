# Environment
ENVIRONMENT=LOCAL
LOGGING_LEVEL=INFO

# Database
POSTGRES_DB=technical_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_POOL_SIZE=20
DATABASE_POOL_SIZE_OVERFLOW=40

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Session
SESSION_EXPIRE_MINUTES=30

# Seed Admin (created on first startup)
SEED_ADMIN_EMAIL=admin@bookstore.com
SEED_ADMIN_PASSWORD=admin123secure
SEED_ADMIN_FULL_NAME=System Admin

# LLM (OpenAI)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5.4-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LLM_MAX_CONCURRENT_REQUESTS=5
